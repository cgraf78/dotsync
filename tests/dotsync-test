#!/usr/bin/env bash
# dotsync-test — unit and integration tests for dotsync.
#
# Creates temp directories to simulate $HOME and tests internal functions
# in isolation. Uses localhost for integration tests (SSH to self).
#
# Usage: dotsync-test [--integration]
#        --integration  also run SSH-based tests (requires localhost SSH)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INTEGRATION=0
REAL_HOME="$HOME"

[[ "${1:-}" == "--integration" ]] && INTEGRATION=1

# shellcheck source=test-helpers.sh
. "$SCRIPT_DIR/test-helpers.sh"

# Extend cleanup to remove integration test files
_dotsync_cleanup() {
    _cleanup
    rm -rf "$REAL_HOME"/.dotsync-test-* 2>/dev/null || true
}
trap _dotsync_cleanup EXIT

# ---------------------------------------------------------------------------
# Source dotsync for internal functions
# ---------------------------------------------------------------------------

# Override HOME and config dirs for testing
TEST_HOME=$(_tmpdir)
export HOME="$TEST_HOME"
export DOTSYNC_CONF_DIR="$TEST_HOME/.config/dotsync"
export DOTSYNC_STATE_DIR="$TEST_HOME/.local/share/dotsync"
export CONF_DIR="$DOTSYNC_CONF_DIR"
export STATE_DIR="$DOTSYNC_STATE_DIR"
export DOTSYNC_SOURCED=1

mkdir -p "$CONF_DIR" "$STATE_DIR"

# shellcheck source=../bin/dotsync
. "$SCRIPT_DIR/../bin/dotsync"

# ---------------------------------------------------------------------------
# Tests: Manifest parsing
# ---------------------------------------------------------------------------

echo "=== Manifest parsing ==="

# Test: basic paths loaded
cat > "$CONF_DIR/dotsync-paths" <<'EOF'
# comment
.bashrc_local

.config/foo
EOF
result=$(_load_paths)
_assert_contains "loads .bashrc_local" ".bashrc_local" "$result"
_assert_contains "loads .config/foo" ".config/foo" "$result"
lines=$(echo "$result" | wc -l | tr -d ' ')
_assert_eq "skips blank lines and comments" "2" "$lines"

# Test: work paths merged (only when tier=work)
cat > "$CONF_DIR/dotsync-paths-work" <<'EOF'
.work_config
EOF
result=$(_load_paths "work")
lines=$(echo "$result" | wc -l | tr -d ' ')
_assert_eq "merges work paths (tier=work)" "3" "$lines"
_assert_contains "includes work path (tier=work)" ".work_config" "$result"

# Test: work paths excluded for personal tier
result=$(_load_paths "personal")
_assert_not_contains "excludes work path (tier=personal)" ".work_config" "$result"

# Test: deduplication
cat > "$CONF_DIR/dotsync-paths-extra" <<'EOF'
.bashrc_local
.extra_file
EOF
result=$(_load_paths "work")
count=$(echo "$result" | grep -c '.bashrc_local')
_assert_eq "deduplicates .bashrc_local" "1" "$count"
_assert_contains "includes extra file" ".extra_file" "$result"

# Cleanup manifests for next tests
rm -f "$CONF_DIR/dotsync-paths-work" "$CONF_DIR/dotsync-paths-extra"

# Test: excludes filter both expansion and explicit includes
cat > "$CONF_DIR/dotsync-paths" <<'EOF'
.config/dot
!.config/dot/dotsync-paths
.local/bin/dotsync
!.local/bin/dotsync
EOF
result=$(_load_paths)
_assert_contains "explicit include passes through _load_paths" ".config/dot" "$result"
_assert_contains "explicitly included+excluded passes through _load_paths" ".local/bin/dotsync" "$result"

# _load_paths doesn't filter — _resolve_local_files does.
# Verify _is_excluded recognizes the exclude pattern.
if _is_excluded ".config/dot/dotsync-paths" ".config/dot/dotsync-paths"; then
    _pass "is_excluded: exact match"
else
    _fail "is_excluded: exact match"
fi
if _is_excluded ".config/dot/sub/file" ".config/dot"; then
    _pass "is_excluded: child of excluded dir"
else
    _fail "is_excluded: child of excluded dir"
fi
if _is_excluded ".config/ds/connect.conf" ".config/dot"; then
    _fail "is_excluded: false positive on sibling"
else
    _pass "is_excluded: no false positive on sibling"
fi

# Glob patterns
if _is_excluded ".config/dot/__pycache__" "*/__pycache__"; then
    _pass "is_excluded: glob */__pycache__"
else
    _fail "is_excluded: glob */__pycache__"
fi
if _is_excluded ".config/dot/__pycache__/module.cpython.pyc" "*/__pycache__"; then
    _pass "is_excluded: glob */__pycache__ matches children"
else
    _fail "is_excluded: glob */__pycache__ matches children"
fi
if _is_excluded "deep/nested/dir/__pycache__/file" "*/__pycache__"; then
    _pass "is_excluded: glob matches across directories"
else
    _fail "is_excluded: glob matches across directories"
fi
if _is_excluded ".config/dot/file.pyc" "*.pyc"; then
    _pass "is_excluded: glob *.pyc"
else
    _fail "is_excluded: glob *.pyc"
fi
if _is_excluded ".config/dot/file.txt" "*.pyc"; then
    _fail "is_excluded: glob *.pyc false positive"
else
    _pass "is_excluded: glob *.pyc no false positive"
fi

# Restore manifest for remaining tests
cat > "$CONF_DIR/dotsync-paths" <<'EOF'
.bashrc_local
.config/foo
EOF

# ---------------------------------------------------------------------------
# Tests: Path validation
# ---------------------------------------------------------------------------

echo ""
echo "=== Path validation ==="

cat > "$CONF_DIR/dotsync-paths" <<'EOF'
.valid_file
/etc/passwd
~/.ssh/id_rsa
../../../etc/shadow
.config/../../../etc/shadow
..
foo/..
.normal_file
$(whoami)
file`cmd`
path;rm -rf /
EOF
result=$(_load_paths 2>/dev/null)
_assert_contains "accepts .valid_file" ".valid_file" "$result"
_assert_contains "accepts .normal_file" ".normal_file" "$result"
_assert_not_contains "rejects absolute path" "/etc/passwd" "$result"
# shellcheck disable=SC2088  # intentional literal tilde in test string
_assert_not_contains "rejects tilde path" "~/.ssh/id_rsa" "$result"
_assert_not_contains "rejects ../ traversal" "../../../etc/shadow" "$result"
_assert_not_contains "rejects embedded ../ traversal" ".config/../../../etc/shadow" "$result"
_assert_not_contains "rejects bare .." ".." "$result"
_assert_not_contains "rejects trailing .." "foo/.." "$result"
_assert_not_contains "rejects dollar sign" "whoami" "$result"
_assert_not_contains "rejects backticks" "cmd" "$result"
_assert_not_contains "rejects semicolon" "path;rm" "$result"
lines=$(echo "$result" | wc -l | tr -d ' ')
_assert_eq "only valid paths remain" "2" "$lines"

# Restore manifest for remaining tests
cat > "$CONF_DIR/dotsync-paths" <<'EOF'
.bashrc_local
.config/foo
EOF

# ---------------------------------------------------------------------------
# Tests: Host parsing
# ---------------------------------------------------------------------------

echo ""
echo "=== Host parsing ==="

cat > "$CONF_DIR/dotsync-hosts" <<'EOF'
# alias    ssh-destination
fileserver        fileserver.example.net
server1    server1.example.com
EOF
result=$(_load_hosts)
_assert_contains "loads fileserver" "fileserver fileserver.example.net" "$result"
_assert_contains "loads server1" "server1 server1.example.com" "$result"

# Test: work hosts merged
cat > "$CONF_DIR/dotsync-hosts-work" <<'EOF'
dev1       dev1.example.com
EOF
result=$(_load_hosts)
_assert_contains "merges work host" "dev1 dev1.example.com" "$result"

# Test: duplicate alias
cat > "$CONF_DIR/dotsync-hosts-work" <<'EOF'
fileserver        other.fileserver.com
dev1       dev1.example.com
EOF
result=$(_load_hosts)
count=$(echo "$result" | grep -c '^fileserver ')
_assert_eq "deduplicates fileserver alias" "1" "$count"
_assert_contains "first occurrence wins" "fileserver.example.net" "$result"

# Test: host resolution
dest=$(_resolve_host "fileserver")
_assert_eq "resolves alias to destination" "fileserver.example.net" "$dest"

dest=$(_resolve_host "unknown.server.com")
_assert_eq "falls back to literal" "unknown.server.com" "$dest"

# Test: host tier detection
# Reset work hosts to avoid leftover from duplicate alias test
cat > "$CONF_DIR/dotsync-hosts-work" <<'EOF'
dev1       dev1.example.com
EOF

tier=$(_host_tier "fileserver")
_assert_eq "personal host tier" "personal" "$tier"

tier=$(_host_tier "dev1")
_assert_eq "work host tier" "work" "$tier"

tier=$(_host_tier "unknown.server.com")
_assert_eq "unknown host defaults to personal" "personal" "$tier"

# Cleanup
rm -f "$CONF_DIR/dotsync-hosts-work"

# ---------------------------------------------------------------------------
# Tests: Self-detection
# ---------------------------------------------------------------------------

echo ""
echo "=== Self-detection ==="

local_fqdn=$(hostname -f 2>/dev/null || hostname)
local_short=$(hostname -s 2>/dev/null || hostname)

if _is_self "$local_fqdn"; then
    _pass "detects self by FQDN ($local_fqdn)"
else
    _fail "detects self by FQDN ($local_fqdn)"
fi

if _is_self "$local_short"; then
    _pass "detects self by short name ($local_short)"
else
    _fail "detects self by short name ($local_short)"
fi

if _is_self "definitely.not.this.host"; then
    _fail "false positive on unrelated host"
else
    _pass "no false positive on unrelated host"
fi

# ---------------------------------------------------------------------------
# Tests: Checksum
# ---------------------------------------------------------------------------

echo ""
echo "=== Checksums ==="

echo "hello world" > "$TEST_HOME/test_file"
hash1=$(_md5 "$TEST_HOME/test_file")
_assert_eq "md5 produces 32-char hash" "32" "${#hash1}"

echo "hello world" > "$TEST_HOME/test_file2"
hash2=$(_md5 "$TEST_HOME/test_file2")
_assert_eq "identical files have same hash" "$hash1" "$hash2"

echo "different content" > "$TEST_HOME/test_file2"
hash3=$(_md5 "$TEST_HOME/test_file2")
if [[ "$hash1" != "$hash3" ]]; then
    _pass "different files have different hashes"
else
    _fail "different files have different hashes"
fi

# Empty file produces valid hash
: > "$TEST_HOME/empty_file"
hash4=$(_md5 "$TEST_HOME/empty_file")
_assert_eq "empty file produces 32-char hash" "32" "${#hash4}"

# Nonexistent file produces empty
hash5=$(_md5 "$TEST_HOME/nonexistent_file" || true)
_assert_eq "nonexistent file produces empty hash" "" "$hash5"

rm -f "$TEST_HOME/test_file" "$TEST_HOME/test_file2" "$TEST_HOME/empty_file"

# ---------------------------------------------------------------------------
# Tests: State management
# ---------------------------------------------------------------------------

echo ""
echo "=== State management ==="

echo "file content" > "$TEST_HOME/state_test"
_save_state "testhost" "state_test" "$TEST_HOME/state_test" "abc123"

stored=$(_get_stored_md5 "testhost" "state_test")
_assert_eq "stored md5 retrieved" "abc123" "$stored"

_assert_file_exists "state file copy exists" "$(_state_file "testhost" "state_test")"
_assert_file_exists "state md5 file exists" "$(_state_md5_file "testhost" "state_test")"

# State file content matches original
_assert_file_content "state file content matches" "file content" "$(_state_file "testhost" "state_test")"

_remove_state "testhost" "state_test"
_assert_file_missing "state file removed" "$(_state_file "testhost" "state_test")"
_assert_file_missing "state md5 removed" "$(_state_md5_file "testhost" "state_test")"

stored=$(_get_stored_md5 "testhost" "state_test")
_assert_eq "empty md5 after removal" "" "$stored"

# Nested path state
mkdir -p "$TEST_HOME/.config/nested"
echo "nested content" > "$TEST_HOME/.config/nested/file"
_save_state "testhost" ".config/nested/file" "$TEST_HOME/.config/nested/file" "def456"
_assert_file_exists "nested state file exists" "$(_state_file "testhost" ".config/nested/file")"
stored=$(_get_stored_md5 "testhost" ".config/nested/file")
_assert_eq "nested state md5 retrieved" "def456" "$stored"
_remove_state "testhost" ".config/nested/file"

rm -f "$TEST_HOME/state_test"
rm -rf "$TEST_HOME/.config/nested"

# ---------------------------------------------------------------------------
# Tests: Binary detection
# ---------------------------------------------------------------------------

echo ""
echo "=== Binary detection ==="

echo "plain text" > "$TEST_HOME/text_file"
if _is_binary "$TEST_HOME/text_file"; then
    _fail "text file detected as binary"
else
    _pass "text file not detected as binary"
fi

printf '\x00\x01\x02\x03' > "$TEST_HOME/binary_file"
if _is_binary "$TEST_HOME/binary_file"; then
    _pass "binary file detected as binary"
else
    _fail "binary file detected as binary"
fi

# Nonexistent file
if _is_binary "$TEST_HOME/no_such_file"; then
    _fail "nonexistent file detected as binary"
else
    _pass "nonexistent file not detected as binary"
fi

rm -f "$TEST_HOME/text_file" "$TEST_HOME/binary_file"

# ---------------------------------------------------------------------------
# Tests: Lock file
# ---------------------------------------------------------------------------

echo ""
echo "=== Lock file ==="

_acquire_lock
_assert_file_exists "lock file created" "$LOCK_FILE"
lock_pid=$(cat "$LOCK_FILE")
_assert_eq "lock contains current PID" "$$" "$lock_pid"
_release_lock
_assert_file_missing "lock file released" "$LOCK_FILE"

# Stale lock detection
echo "99999999" > "$LOCK_FILE"
_acquire_lock  # should succeed (PID 99999999 doesn't exist)
_assert_eq "stale lock replaced with current PID" "$$" "$(cat "$LOCK_FILE")"
_release_lock

# ---------------------------------------------------------------------------
# Tests: Path expansion (local)
# ---------------------------------------------------------------------------

echo ""
echo "=== Path expansion ==="

mkdir -p "$TEST_HOME/.config/testdir/sub"
echo "a" > "$TEST_HOME/.config/testdir/file1"
echo "b" > "$TEST_HOME/.config/testdir/sub/file2"
echo "c" > "$TEST_HOME/standalone"

result=$(_expand_paths_local "$TEST_HOME" ".config/testdir" "standalone")
_assert_contains "expands dir to file1" ".config/testdir/file1" "$result"
_assert_contains "expands dir to sub/file2" ".config/testdir/sub/file2" "$result"
_assert_contains "passes through standalone file" "standalone" "$result"

# Missing path produces no output
result=$(_expand_paths_local "$TEST_HOME" "nonexistent")
_assert_eq "missing path produces empty" "" "$result"

# Dangling symlink excluded
ln -sf "$TEST_HOME/no_target" "$TEST_HOME/dangling_link"
result=$(_expand_paths_local "$TEST_HOME" "dangling_link")
_assert_eq "dangling symlink excluded" "" "$result"

# Glob expansion in includes
echo "x" > "$TEST_HOME/.bashrc_local"
echo "y" > "$TEST_HOME/.bashrc_work"
echo "z" > "$TEST_HOME/.bashrc_test"
result=$(_expand_paths_local "$TEST_HOME" ".bashrc_*")
_assert_contains "glob expands .bashrc_local" ".bashrc_local" "$result"
_assert_contains "glob expands .bashrc_work" ".bashrc_work" "$result"
_assert_contains "glob expands .bashrc_test" ".bashrc_test" "$result"

# Glob with no matches produces no output
result=$(_expand_paths_local "$TEST_HOME" ".no_match_*")
_assert_eq "glob no match produces empty" "" "$result"

# Symlink to file inside directory is included
mkdir -p "$TEST_HOME/.config/linkdir" "$TEST_HOME/.link-targets"
echo "target content" > "$TEST_HOME/.link-targets/real_file"
echo "regular" > "$TEST_HOME/.config/linkdir/regular"
ln -s "$TEST_HOME/.link-targets/real_file" "$TEST_HOME/.config/linkdir/linked_file"
result=$(_expand_paths_local "$TEST_HOME" ".config/linkdir")
_assert_contains "dir expansion includes regular file" ".config/linkdir/regular" "$result"
_assert_contains "dir expansion includes symlink to file" ".config/linkdir/linked_file" "$result"

# Symlink to directory inside directory is NOT expanded
mkdir -p "$TEST_HOME/.link-targets/subdir"
echo "deep" > "$TEST_HOME/.link-targets/subdir/deep_file"
ln -s "$TEST_HOME/.link-targets/subdir" "$TEST_HOME/.config/linkdir/linked_dir"
result=$(_expand_paths_local "$TEST_HOME" ".config/linkdir")
_assert_not_contains "dir expansion skips symlink to directory" "deep_file" "$result"

# Dangling symlink inside directory is skipped
ln -sf "$TEST_HOME/no_such_target" "$TEST_HOME/.config/linkdir/broken_link"
result=$(_expand_paths_local "$TEST_HOME" ".config/linkdir")
_assert_not_contains "dir expansion skips dangling symlink" "broken_link" "$result"

# Glob expansion also includes symlinks to files
echo "g" > "$TEST_HOME/.linktest_a"
ln -s "$TEST_HOME/.link-targets/real_file" "$TEST_HOME/.linktest_b"
result=$(_expand_paths_local "$TEST_HOME" ".linktest_*")
_assert_contains "glob includes regular file" ".linktest_a" "$result"
_assert_contains "glob includes symlink to file" ".linktest_b" "$result"

rm -f "$TEST_HOME/.linktest_a" "$TEST_HOME/.linktest_b"
rm -rf "$TEST_HOME/.config/linkdir" "$TEST_HOME/.link-targets"

rm -f "$TEST_HOME/.bashrc_local" "$TEST_HOME/.bashrc_work" "$TEST_HOME/.bashrc_test"
rm -rf "$TEST_HOME/.config/testdir" "$TEST_HOME/standalone" "$TEST_HOME/dangling_link"

# ---------------------------------------------------------------------------
# Tests: list and hosts commands
# ---------------------------------------------------------------------------

echo ""
echo "=== Commands ==="

# Create files so _do_list can find them via expansion
echo "test" > "$TEST_HOME/.bashrc_local"
mkdir -p "$TEST_HOME/.config/foo"
echo "test" > "$TEST_HOME/.config/foo/bar"
result=$(_do_list)
_assert_contains "list shows .bashrc_local" ".bashrc_local" "$result"
_assert_contains "list shows expanded dir contents" ".config/foo/bar" "$result"
# Excludes always win, even against explicit includes
cat > "$CONF_DIR/dotsync-paths" <<'EOF'
.config/mydir
.config/mydir/secret_work
!*_work
EOF
mkdir -p "$TEST_HOME/.config/mydir"
echo "a" > "$TEST_HOME/.config/mydir/file1"
echo "b" > "$TEST_HOME/.config/mydir/stuff_work"
echo "c" > "$TEST_HOME/.config/mydir/secret_work"
result=$(_resolve_local_files "personal")
_assert_not_contains "exclude beats explicit include" "secret_work" "$result"
_assert_contains "non-excluded expansion passes" "file1" "$result"
_assert_not_contains "exclude filters dir expansion" "stuff_work" "$result"
rm -rf "$TEST_HOME/.config/mydir"

# Work manifest paths are excluded from personal-tier directory expansion.
# A file listed in dotsync-paths-work should never leak to personal hosts
# via expansion of a personal-tier directory, even without a naming convention.
cat > "$CONF_DIR/dotsync-paths" <<'EOF'
.config/ds
EOF
cat > "$CONF_DIR/dotsync-paths-work" <<'EOF'
.config/ds/profile-orc.sh
.config/ds/connect-work.conf
EOF
mkdir -p "$TEST_HOME/.config/ds"
echo "a" > "$TEST_HOME/.config/ds/profiles.sh"
echo "b" > "$TEST_HOME/.config/ds/profile-orc.sh"
echo "c" > "$TEST_HOME/.config/ds/connect-work.conf"
result=$(_resolve_local_files "personal")
_assert_contains "personal tier includes non-work file" "profiles.sh" "$result"
_assert_not_contains "work manifest path excluded from personal tier" "profile-orc.sh" "$result"
_assert_not_contains "work manifest path excluded from personal tier" "connect-work.conf" "$result"
# Work tier should include all files
result=$(_resolve_local_files "work")
_assert_contains "work tier includes work file" "profile-orc.sh" "$result"
_assert_contains "work tier includes non-work file" "profiles.sh" "$result"
rm -rf "$TEST_HOME/.config/ds"
rm -f "$CONF_DIR/dotsync-paths-work"

# Work manifest glob patterns are NOT used as personal-tier excludes
# (too fuzzy — could accidentally exclude personal files).
cat > "$CONF_DIR/dotsync-paths" <<'EOF'
.config/ds
EOF
cat > "$CONF_DIR/dotsync-paths-work" <<'EOF'
.config/ds/profile-*.sh
EOF
mkdir -p "$TEST_HOME/.config/ds"
echo "a" > "$TEST_HOME/.config/ds/profiles.sh"
echo "b" > "$TEST_HOME/.config/ds/profile-orc.sh"
result=$(_resolve_local_files "personal")
_assert_contains "personal tier includes non-work file" "profiles.sh" "$result"
_assert_contains "work glob not used as personal exclude" "profile-orc.sh" "$result"
rm -rf "$TEST_HOME/.config/ds"
rm -f "$CONF_DIR/dotsync-paths-work"

# Restore manifest for remaining tests
cat > "$CONF_DIR/dotsync-paths" <<'EOF'
.bashrc_local
.config/foo
EOF
rm -f "$TEST_HOME/.bashrc_local"
rm -rf "$TEST_HOME/.config/foo"

result=$(_do_hosts)
_assert_contains "hosts shows fileserver" "fileserver" "$result"

# ---------------------------------------------------------------------------
# Tests: Symlink preservation
# ---------------------------------------------------------------------------

echo ""
echo "=== Symlink preservation ==="

# Setup: create a symlink target and a symlink pointing to it
mkdir -p "$TEST_HOME/.symlink-targets"
echo "original content" > "$TEST_HOME/.symlink-targets/config"
ln -s "$TEST_HOME/.symlink-targets/config" "$TEST_HOME/symlink_file"

# _record_local_symlinks captures symlinks
result=$(_record_local_symlinks "symlink_file")
_assert_contains "records symlink path" "symlink_file" "$result"
_assert_contains "records symlink target" ".symlink-targets/config" "$result"

# _record_local_symlinks ignores regular files
echo "regular" > "$TEST_HOME/regular_file"
result=$(_record_local_symlinks "regular_file")
_assert_eq "ignores regular file" "" "$result"

# _restore_local_symlinks restores a clobbered symlink
saved=$(_record_local_symlinks "symlink_file")
# Simulate rsync clobber: replace symlink with regular file
rm "$TEST_HOME/symlink_file"
echo "updated content" > "$TEST_HOME/symlink_file"
# Verify symlink is gone
if [[ -L "$TEST_HOME/symlink_file" ]]; then
    _fail "setup: symlink should be clobbered"
else
    _pass "setup: symlink clobbered by regular file"
fi
# Restore
echo "$saved" | _restore_local_symlinks
# Verify symlink is restored
if [[ -L "$TEST_HOME/symlink_file" ]]; then
    _pass "symlink restored after clobber"
else
    _fail "symlink restored after clobber"
fi
# Verify content was written through to target
_assert_file_content "content written to symlink target" "updated content" "$TEST_HOME/.symlink-targets/config"
# Verify reading through the symlink returns the new content
actual=$(cat "$TEST_HOME/symlink_file")
_assert_eq "symlink reads updated content" "updated content" "$actual"

# _record_local_symlinks produces nothing for regular files, so
# _restore_local_symlinks is a no-op — regular files are never touched.
echo "regular content" > "$TEST_HOME/regular_file"
saved_regular=$(_record_local_symlinks "regular_file")
_assert_eq "regular file produces no saved links" "" "$saved_regular"

rm -f "$TEST_HOME/symlink_file" "$TEST_HOME/regular_file"
rm -rf "$TEST_HOME/.symlink-targets"

# Relative symlink: target is relative to the symlink's parent directory
mkdir -p "$TEST_HOME/.orc" "$TEST_HOME/.dotfiles-work/home/.orc"
echo "original" > "$TEST_HOME/.dotfiles-work/home/.orc/config"
ln -s "../.dotfiles-work/home/.orc/config" "$TEST_HOME/.orc/config"
saved=$(_record_local_symlinks ".orc/config")
_assert_contains "records relative symlink" "../.dotfiles-work" "$saved"
# Simulate clobber
rm "$TEST_HOME/.orc/config"
echo "updated" > "$TEST_HOME/.orc/config"
echo "$saved" | _restore_local_symlinks
if [[ -L "$TEST_HOME/.orc/config" ]]; then
    _pass "relative symlink restored"
else
    _fail "relative symlink restored"
fi
_assert_file_content "relative symlink: content written to target" "updated" "$TEST_HOME/.dotfiles-work/home/.orc/config"
actual=$(cat "$TEST_HOME/.orc/config")
_assert_eq "relative symlink reads updated content" "updated" "$actual"
rm -rf "$TEST_HOME/.orc" "$TEST_HOME/.dotfiles-work"

# Broken symlinks are skipped by _record_local_symlinks
ln -sf "$TEST_HOME/no_such_target" "$TEST_HOME/broken_symlink"
result=$(_record_local_symlinks "broken_symlink")
_assert_eq "broken symlink skipped by record" "" "$result"
rm -f "$TEST_HOME/broken_symlink"

# REMOTE_MD5_SCRIPT reports BROKEN for broken symlinks
mkdir -p "$TEST_HOME/.broken-test"
ln -sf "$TEST_HOME/no_such_target" "$TEST_HOME/.broken-test/link"
echo "real" > "$TEST_HOME/.broken-test/file"
result=$(printf '%s\n' ".broken-test/link" ".broken-test/file" | HOME="$TEST_HOME" bash -c "$REMOTE_MD5_SCRIPT")
_assert_contains "REMOTE_MD5_SCRIPT: broken symlink → BROKEN" "BROKEN .broken-test/link" "$result"
_assert_contains "REMOTE_MD5_SCRIPT: regular file → EXISTS" "EXISTS" "$result"
# Missing files
result=$(printf '%s\n' "no_such_file" | HOME="$TEST_HOME" bash -c "$REMOTE_MD5_SCRIPT")
_assert_contains "REMOTE_MD5_SCRIPT: missing file → MISSING" "MISSING no_such_file" "$result"
rm -rf "$TEST_HOME/.broken-test"

# ---------------------------------------------------------------------------
# Integration tests (SSH to localhost)
# ---------------------------------------------------------------------------

if [[ $INTEGRATION -eq 1 ]]; then
    echo ""
    echo "=== Integration (localhost SSH) ==="

    # Restore real HOME for SSH operations — localhost SSH inherits
    # the exported HOME, so local and remote must use the same HOME.
    export HOME="$REAL_HOME"
    INT_CONF=$(_tmpdir)
    INT_STATE=$(_tmpdir)
    CONF_DIR="$INT_CONF"
    STATE_DIR="$INT_STATE"
    LOCK_FILE="$INT_STATE/.lock"
    TEST_REL=".dotsync-test-$$"

    if ! _ssh_probe "localhost"; then
        echo "  SKIP: localhost SSH not available"
    else
        _pass "localhost SSH probe succeeds"

        # --- Setup ---
        # Both local and remote see REAL_HOME via localhost SSH.
        # We manipulate stored state to simulate divergent local/remote views.
        mkdir -p "$HOME/$TEST_REL"

        cat > "$CONF_DIR/dotsync-paths" <<EOF
$TEST_REL/file_a
EOF
        cat > "$CONF_DIR/dotsync-hosts" <<'EOF'
testhost   localhost
EOF

        # ---------------------------------------------------------------
        echo ""
        echo "  --- First sync and state ---"

        # First sync: file exists on both sides (same machine), same content
        echo "initial" > "$HOME/$TEST_REL/file_a"
        _sync_host "testhost" "localhost" "personal" 0 > /dev/null 2>&1 || true
        _assert_file_exists "first sync: state created" "$(_state_md5_file "testhost" "$TEST_REL/file_a")"
        stored=$(_get_stored_md5 "testhost" "$TEST_REL/file_a")
        expected=$(_md5 "$HOME/$TEST_REL/file_a")
        _assert_eq "first sync: state matches file" "$expected" "$stored"

        # Second sync: nothing changed → up to date
        result=$(_sync_host "testhost" "localhost" "personal" 1 2>&1)
        _assert_contains "no changes → up to date" "(up to date)" "$result"

        # ---------------------------------------------------------------
        echo ""
        echo "  --- Decision matrix via state manipulation ---"
        # By writing incorrect stored state, we simulate divergent
        # local/remote views even though they're the same filesystem.

        # Simulate "local changed, remote unchanged":
        # Set stored state to a fake hash. Local file has real hash.
        # Remote (same file) also has real hash. So both appear "changed"
        # relative to state, but same as each other → "both changed same"
        echo "abc000fake" > "$(_state_md5_file "testhost" "$TEST_REL/file_a")"
        result=$(_sync_host "testhost" "localhost" "personal" 1 2>&1)
        _assert_contains "stale state, same content → up to date" "(up to date)" "$result"
        # Execute to update state
        _sync_host "testhost" "localhost" "personal" 0 > /dev/null 2>&1 || true

        # Simulate "file missing locally" (= also missing remotely on localhost):
        # Delete file, stored state exists. File won't appear in path
        # expansion (missing on both sides), so stale state persists harmlessly.
        rm -f "$HOME/$TEST_REL/file_a"
        _sync_host "testhost" "localhost" "personal" 0 > /dev/null 2>&1 || true
        stored=$(_get_stored_md5 "testhost" "$TEST_REL/file_a")
        if [[ -n "$stored" ]]; then
            _pass "both deleted → stale state persists (harmless)"
        else
            _pass "both deleted → state cleaned"
        fi

        # File missing everywhere, no files to process → early return, no output
        rm -rf "$INT_STATE/testhost"
        result=$(_sync_host "testhost" "localhost" "personal" 1 2>&1)
        _assert_eq "missing everywhere → no output" "" "$result"

        # ---------------------------------------------------------------
        echo ""
        echo "  --- Push/pull commands ---"

        rm -rf "$INT_STATE/testhost"
        echo "push test" > "$HOME/$TEST_REL/file_a"

        # Dry-run push
        DRY_RUN=1
        result=$(_do_push "testhost" 2>&1)
        DRY_RUN=0
        _assert_contains "dry-run push shows file" "file_a" "$result"
        _assert_contains "dry-run push says 'would'" "would push" "$result"

        # Actual push (localhost → same file, but tests rsync + state)
        _do_push "testhost" > /dev/null 2>&1
        _assert_file_exists "push creates state" "$(_state_md5_file "testhost" "$TEST_REL/file_a")"
        stored=$(_get_stored_md5 "testhost" "$TEST_REL/file_a")
        expected=$(_md5 "$HOME/$TEST_REL/file_a")
        _assert_eq "push state matches file" "$expected" "$stored"

        # Actual pull (localhost → same file, but tests rsync + state)
        rm -rf "$INT_STATE/testhost"
        _do_pull "testhost" > /dev/null 2>&1
        _assert_file_exists "pull creates state" "$(_state_md5_file "testhost" "$TEST_REL/file_a")"

        # Dry-run pull
        DRY_RUN=1
        result=$(_do_pull "testhost" 2>&1)
        DRY_RUN=0
        _assert_contains "dry-run pull shows file" "file_a" "$result"
        _assert_contains "dry-run pull says 'would'" "would pull" "$result"

        # ---------------------------------------------------------------
        echo ""
        echo "  --- Diff command ---"

        rm -rf "$INT_STATE/testhost"
        result=$(_do_diff "testhost" 2>&1)
        _assert_contains "diff shows host" "testhost" "$result"

        # ---------------------------------------------------------------
        echo ""
        echo "  --- Self-detection in sync ---"

        # Configure current machine as a host — should be skipped
        local_fqdn=$(hostname -f 2>/dev/null || hostname)
        cat > "$CONF_DIR/dotsync-hosts" <<EOF
self       $local_fqdn
testhost   localhost
EOF
        result=$(_do_sync 2>&1)
        _assert_not_contains "self host skipped from sync" "self ($local_fqdn):" "$result"
        _assert_contains "non-self host synced" "testhost" "$result"

        # Cleanup integration test files
        rm -rf "${HOME:?}/${TEST_REL:?}"
    fi

    # Restore test HOME for summary
    export HOME="$TEST_HOME"
fi

_test_summary
